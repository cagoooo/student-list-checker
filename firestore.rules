rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isSchoolAccount() {
      return signedIn()
        && request.auth.token.email is string
        && request.auth.token.email.matches('.*@mail2\\.smes\\.tyc\\.edu\\.tw$');
    }

    function isAdmin() {
      return signedIn()
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    match /admins/{uid} {
      allow read: if signedIn() && request.auth.uid == uid;
      allow write: if false;
    }

    match /students/{studentId} {
      // 讀取：全校 @mail2 帳號（一般老師可校對自己班的名單）
      allow read: if isSchoolAccount();
      // 寫入：僅限 admins（資訊組長）更新學生資料庫
      allow write: if isAdmin() && isSchoolAccount();
    }

    match /studentDatabaseMeta/{docId} {
      allow read: if isSchoolAccount();
      allow write: if isAdmin() && isSchoolAccount();
    }

    match /uploads/{uploadId} {
      allow read, write: if isAdmin() && isSchoolAccount();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
