modules = ["nodejs-20", "web"]
[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run dev"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[ports]]
localPort = 5000
externalPort = 80

[deployment]
deploymentTarget = "static"
build = ["npm", "run", "build"]
publicDir = "dist"

[userenv]

[userenv.shared]
VITE_FIREBASE_AUTH_DOMAIN = "mbti-classroom-smes.firebaseapp.com"
VITE_FIREBASE_PROJECT_ID = "mbti-classroom-smes"
VITE_FIREBASE_STORAGE_BUCKET = "mbti-classroom-smes.firebasestorage.app"
VITE_FIREBASE_MESSAGING_SENDER_ID = "18879978724"
VITE_FIREBASE_APP_ID = "1:18879978724:web:5b3d7bdb41338565f3a0f1"
VITE_FIREBASE_FUNCTIONS_REGION = "asia-east1"
